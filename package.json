{
  "name": "paper-cortex",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "tsx watch src/main.ts",
    "start": "node --enable-source-maps dist/main.js",
    "build": "tsc -p tsconfig.json",
    "check": "tsc -p tsconfig.json --noEmit && eslint .",
    "install:launchd": "bash scripts/install-launchd.sh",
    "uninstall:launchd": "bash scripts/uninstall-launchd.sh"
  },
  "dependencies": {
    "@mariozechner/pi-ai": "file:../pi-mono/packages/ai",
    "@mariozechner/pi-agent-core": "file:../pi-mono/packages/agent",
    "chokidar": "^4.0.3",
    "dotenv": "^16.4.7"
  },
  "devDependencies": {
    "@eslint/js": "^9.19.0",
    "@modelcontextprotocol/sdk": "^1.18.1",
    "@types/node": "^22.13.8",
    "eslint": "^9.19.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.26.0"
  }
}
