# Copy to .env and fill in
OPENAI_API_KEY=sk-...

# Optional: override defaults
# PAPER_CORTEX_MODEL=gpt-4.1-mini
# PAPER_CORTEX_INBOX_DIR="$HOME/Google Drive/My Drive/Saved from Chrome"
# PAPER_CORTEX_LIBRARY_DIR="$HOME/Google Drive/My Drive/Papers"
# PAPER_CORTEX_OBSIDIAN_VAULT_DIR="$HOME/MIT:WHOI/Research"
# PAPER_CORTEX_IDEA_LOG_FILE="$HOME/MIT:WHOI/Research/Idea Log.md"
# PAPER_CORTEX_CLEANUP_EVERY_DAYS=10
# PAPER_CORTEX_MAX_REORG_MOVES=20
# PAPER_CORTEX_REORG_CONFIDENCE=0.85
# PAPER_CORTEX_MAX_NEW_CONCEPTS_PER_INGEST=8
# PAPER_CORTEX_PAPER_MATH_SUMMARY_PAGES=0 # 0 = all pages
# PAPER_CORTEX_PAPER_MATH_SUMMARY_STARTUP_MAX=3
